{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/41490/chao5whistler/blob/main/src/musikalisches/runtime/config/stage6_scene_profile.schema.json",
  "title": "Musikalisches Stage 6 Scene Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile_id",
    "description",
    "canvas",
    "palette",
    "motion",
    "preview",
    "title_area",
    "soundscape_badges",
    "footer_progress_area",
    "selector_label_sprites",
    "spectrum_trails",
    "short_safe_layout",
    "text_overrides"
  ],
  "properties": {
    "profile_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "enum": [
        "repo_default",
        "cli"
      ]
    },
    "source_path": {
      "type": "string",
      "minLength": 1
    },
    "canvas": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "width",
        "height",
        "fps"
      ],
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 320
        },
        "height": {
          "type": "integer",
          "minimum": 240
        },
        "fps": {
          "type": "integer",
          "minimum": 1,
          "maximum": 60
        }
      }
    },
    "palette": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "palette_id",
        "background_color",
        "panel_color",
        "grid_color",
        "text_color",
        "accent_sequence",
        "colors"
      ],
      "properties": {
        "palette_id": {
          "type": "string",
          "minLength": 1
        },
        "background_color": {
          "$ref": "#/$defs/hexColor"
        },
        "panel_color": {
          "$ref": "#/$defs/hexColor"
        },
        "grid_color": {
          "$ref": "#/$defs/hexColor"
        },
        "text_color": {
          "$ref": "#/$defs/hexColor"
        },
        "accent_sequence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "colors": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/hexColor"
          },
          "propertyNames": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "motion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "clock_source",
        "keyframe_source",
        "rotation_degrees_per_second",
        "base_scale",
        "envelope_scale_range",
        "grid_alpha_base",
        "grid_alpha_range",
        "lane_center_y_ratio",
        "lane_bias_y_range_ratio",
        "lane_energy_base",
        "lane_energy_scale",
        "lane_wave_height_px",
        "lane_orbit_px",
        "lane_orbit_wave_px",
        "base_radius_px",
        "radius_range_px",
        "base_opacity",
        "opacity_range",
        "base_stroke_width_px",
        "stroke_width_range_px"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "minLength": 1
        },
        "clock_source": {
          "type": "string",
          "minLength": 1
        },
        "keyframe_source": {
          "type": "string",
          "minLength": 1
        },
        "rotation_degrees_per_second": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "base_scale": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "envelope_scale_range": {
          "type": "number",
          "minimum": 0
        },
        "grid_alpha_base": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "grid_alpha_range": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "lane_center_y_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "lane_bias_y_range_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "lane_energy_base": {
          "type": "number",
          "minimum": 0
        },
        "lane_energy_scale": {
          "type": "number",
          "minimum": 0
        },
        "lane_wave_height_px": {
          "type": "number",
          "minimum": 0
        },
        "lane_orbit_px": {
          "type": "number",
          "minimum": 0
        },
        "lane_orbit_wave_px": {
          "type": "number",
          "minimum": 0
        },
        "base_radius_px": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "radius_range_px": {
          "type": "number",
          "minimum": 0
        },
        "base_opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "opacity_range": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "base_stroke_width_px": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "stroke_width_range_px": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "preview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sampled_window_limit",
        "title",
        "geometry_label",
        "envelope_label"
      ],
      "properties": {
        "sampled_window_limit": {
          "type": "integer",
          "minimum": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "geometry_label": {
          "type": "string",
          "minLength": 1
        },
        "envelope_label": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "title_area": {
      "allOf": [
        {
          "$ref": "#/$defs/rect"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "x",
            "y",
            "width",
            "height",
            "max_lines",
            "layout_strategy",
            "text_align",
            "base_font_size_px",
            "line_gap_px"
          ],
          "properties": {
            "x": {
              "type": "integer",
              "minimum": 0
            },
            "y": {
              "type": "integer",
              "minimum": 0
            },
            "width": {
              "type": "integer",
              "minimum": 1
            },
            "height": {
              "type": "integer",
              "minimum": 1
            },
            "max_lines": {
              "type": "integer",
              "minimum": 1,
              "maximum": 2
            },
            "layout_strategy": {
              "type": "string",
              "const": "explicit_newlines_centered"
            },
            "text_align": {
              "type": "string",
              "const": "center"
            },
            "base_font_size_px": {
              "type": "integer",
              "minimum": 1
            },
            "line_gap_px": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      ]
    },
    "soundscape_badges": {
      "allOf": [
        {
          "$ref": "#/$defs/rect"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "x",
            "y",
            "width",
            "height",
            "badge_gap_px",
            "font_size_px"
          ],
          "properties": {
            "x": {
              "type": "integer",
              "minimum": 0
            },
            "y": {
              "type": "integer",
              "minimum": 0
            },
            "width": {
              "type": "integer",
              "minimum": 1
            },
            "height": {
              "type": "integer",
              "minimum": 1
            },
            "badge_gap_px": {
              "type": "integer",
              "minimum": 0
            },
            "font_size_px": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      ]
    },
    "footer_progress_area": {
      "allOf": [
        {
          "$ref": "#/$defs/rect"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "x",
            "y",
            "width",
            "height",
            "format_template",
            "text_align",
            "font_size_px"
          ],
          "properties": {
            "x": {
              "type": "integer",
              "minimum": 0
            },
            "y": {
              "type": "integer",
              "minimum": 0
            },
            "width": {
              "type": "integer",
              "minimum": 1
            },
            "height": {
              "type": "integer",
              "minimum": 1
            },
            "format_template": {
              "type": "string",
              "minLength": 1
            },
            "text_align": {
              "type": "string",
              "const": "center"
            },
            "font_size_px": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      ]
    },
    "selector_label_sprites": {
      "allOf": [
        {
          "$ref": "#/$defs/rect"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "x",
            "y",
            "width",
            "height",
            "random_seed_source",
            "label_min_font_size_px",
            "label_max_font_size_px",
            "label_padding_px",
            "idle_drift_px",
            "idle_rotation_degrees",
            "active_bounce_y_px",
            "active_scale_multiplier"
          ],
          "properties": {
            "x": {
              "type": "integer",
              "minimum": 0
            },
            "y": {
              "type": "integer",
              "minimum": 0
            },
            "width": {
              "type": "integer",
              "minimum": 1
            },
            "height": {
              "type": "integer",
              "minimum": 1
            },
            "random_seed_source": {
              "type": "string",
              "const": "selection.combination_id"
            },
            "label_min_font_size_px": {
              "type": "integer",
              "minimum": 1
            },
            "label_max_font_size_px": {
              "type": "integer",
              "minimum": 1
            },
            "label_padding_px": {
              "type": "integer",
              "minimum": 0
            },
            "idle_drift_px": {
              "type": "integer",
              "minimum": 0
            },
            "idle_rotation_degrees": {
              "type": "integer",
              "minimum": 0
            },
            "active_bounce_y_px": {
              "type": "integer",
              "minimum": 0
            },
            "active_scale_multiplier": {
              "type": "number",
              "minimum": 1
            }
          }
        }
      ]
    },
    "spectrum_trails": {
      "allOf": [
        {
          "$ref": "#/$defs/rect"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "x",
            "y",
            "width",
            "height",
            "trail_count",
            "envelope_floor",
            "envelope_ceiling",
            "stroke_min_width_px",
            "stroke_max_width_px",
            "alpha_base",
            "alpha_range"
          ],
          "properties": {
            "x": {
              "type": "integer",
              "minimum": 0
            },
            "y": {
              "type": "integer",
              "minimum": 0
            },
            "width": {
              "type": "integer",
              "minimum": 1
            },
            "height": {
              "type": "integer",
              "minimum": 1
            },
            "trail_count": {
              "type": "integer",
              "minimum": 1
            },
            "envelope_floor": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "envelope_ceiling": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "stroke_min_width_px": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "stroke_max_width_px": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "alpha_base": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "alpha_range": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        }
      ]
    },
    "short_safe_layout": {
      "allOf": [
        {
          "$ref": "#/$defs/rect"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "x",
            "y",
            "width",
            "height",
            "target_aspect_ratio"
          ],
          "properties": {
            "x": {
              "type": "integer",
              "minimum": 0
            },
            "y": {
              "type": "integer",
              "minimum": 0
            },
            "width": {
              "type": "integer",
              "minimum": 1
            },
            "height": {
              "type": "integer",
              "minimum": 1
            },
            "target_aspect_ratio": {
              "type": "string",
              "const": "9:16"
            }
          }
        }
      ]
    },
    "text_overrides": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default_toml_path",
        "toml_section",
        "title_key",
        "newline_mode",
        "horizontal_alignment",
        "max_title_lines"
      ],
      "properties": {
        "default_toml_path": {
          "type": "string",
          "minLength": 1
        },
        "toml_section": {
          "type": "string",
          "minLength": 1
        },
        "title_key": {
          "type": "string",
          "minLength": 1
        },
        "newline_mode": {
          "type": "string",
          "const": "escaped_or_literal_newline"
        },
        "horizontal_alignment": {
          "type": "string",
          "const": "center"
        },
        "max_title_lines": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2
        }
      }
    }
  },
  "$defs": {
    "hexColor": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$"
    },
    "rect": {
      "type": "object",
      "required": [
        "x",
        "y",
        "width",
        "height"
      ]
    }
  }
}
