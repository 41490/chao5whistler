{
  "profile_id": "stage7_default_rtmps_h264_aac_720p30",
  "description": "Default stage7 RTMPS bridge contract for 1280x720@30fps H.264/AAC live output with local FLV smoke validation.",
  "ingest": {
    "protocol": "rtmps",
    "container": "flv",
    "stream_url_env": "MUSIKALISCHES_RTMP_URL",
    "stream_url_example": "rtmps://a.rtmps.youtube.com/live2/<stream-key>"
  },
  "video": {
    "width": 1280,
    "height": 720,
    "fps": 30,
    "codec": "h264",
    "encoder": "libx264",
    "preset": "ultrafast",
    "pixel_format": "yuv420p",
    "bitrate_kbps": 4000,
    "maxrate_kbps": 4000,
    "bufsize_kbps": 8000,
    "gop_seconds": 2,
    "keyframe_interval_frames": 60,
    "pixel_aspect_ratio": "1:1",
    "scan_mode": "progressive"
  },
  "audio": {
    "codec": "aac",
    "sample_rate_hz": 44100,
    "channels": 2,
    "bitrate_kbps": 128
  },
  "smoke": {
    "enabled": true,
    "container": "flv",
    "muxer": "flv",
    "output_file": "stage7_bridge_smoke.flv"
  }
}
